# Avoma REST API authentication
AVOMA_API_KEY=

# Claude AI (Anthropic) API authentication
ANTHROPIC_API_KEY=

# Anthropic model used for analysis (Claude Sonnet)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Limit number of accounts processed per sync (0 / unset = unlimited)
MAX_DEALS=0

# Server port (Railway sets this automatically; defaults to 3000 locally)
# PORT=8080
