# Avoma REST API authentication
AVOMA_API_KEY=

# Claude AI (Anthropic) API authentication
ANTHROPIC_API_KEY=

# Anthropic model for analysis (Claude Sonnet)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Limit number of accounts processed per sync (0 = unlimited)
MAX_DEALS=0

# Where the SQLite database file lives. In production (Railway) point this at
# the persistent volume, e.g. /app/data/duro-tracks.db
DATA_DIR=./data

# Client-side passcode gate (sessionStorage). Exposed to the browser.
NEXT_PUBLIC_APP_PASSCODE=duro

# Server port (Railway sets this automatically; defaults to 8080)
PORT=8080
